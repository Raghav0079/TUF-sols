{
    "version": "2.0.0",
    "tasks": [

        {
            "label": "Compile and run C++",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "copy",
                "\"${file}\"",
                "jspwTest.cpp",
                "&&",
                "g++",
                "jspwTest.cpp",
                "-o",
                "jspwTest",
                "&&",
                "jspwTest",
                "<",
                "input.txt",
                ">",
                "output.txt",
                "&&",
                "del",
                "jspwTest.exe",
                "&&",
                "del",
                "jspwTest.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },

        {
            "label": "Compile and run Java",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "javac",
                "${file}",
                "&&",
                "java",
                "${fileBasenameNoExtension}",
                "<",
                "input.txt",
                ">",
                "output.txt"
            ],
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}